<ui:FluentWindow x:Class="GameTrainerLauncher.UI.Views.TrainerVersionPickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{DynamicResource TrainerVersionDialogTitle}"
                 Height="560"
                 Width="860"
                 MinHeight="560"
                 MinWidth="860"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 Icon="/Assets/logo.ico"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Foreground="{DynamicResource DialogTextBrush}">
    <Window.Resources>
        <Style x:Key="TrainerVersionActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="TrainerVersionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource DialogMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TrainerVersionCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource DialogTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{DynamicResource TrainerVersionDialogTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/logo.ico" Width="16" Height="16" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="18"
                    Background="{DynamicResource DialogHeaderBrush}"
                    BorderBrush="{DynamicResource DialogBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock x:Name="SummaryText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DialogAccentBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource DialogMutedBrush}"
                               Text="{DynamicResource TrainerVersionDialogHint}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="{DynamicResource DialogCardBrush}"
                    BorderBrush="{DynamicResource DialogBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid Margin="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,14,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource TrainerVersionHeaderTextStyle}"
                                   Text="{DynamicResource TrainerVersionColumnVersion}" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource TrainerVersionHeaderTextStyle}"
                                   Text="{DynamicResource TrainerVersionColumnDate}" />
                        <TextBlock Grid.Column="2"
                                   Style="{StaticResource TrainerVersionHeaderTextStyle}"
                                   Text="{DynamicResource TrainerVersionColumnSize}" />
                    </Grid>

                    <ListView x:Name="OptionsListView"
                              Grid.Row="1"
                              Margin="10,0,10,10"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Padding" Value="10" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource TrainerVersionCellTextStyle}"
                                               Margin="0,0,12,0"
                                               Text="{Binding Label}" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource TrainerVersionCellTextStyle}"
                                               Margin="0,0,12,0"
                                               Text="{Binding PublishedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}" />
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource TrainerVersionCellTextStyle}"
                                               Text="{Binding FileSizeText, TargetNullValue=-}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DialogMutedBrush}"
                           Text="{DynamicResource TrainerVersionDialogFooter}" />

                <ui:Button DockPanel.Dock="Right"
                           Style="{StaticResource TrainerVersionActionButtonStyle}"
                           Appearance="Primary"
                           Click="Confirm_Click"
                           Content="{DynamicResource TrainerVersionConfirm}" />
                <ui:Button DockPanel.Dock="Right"
                           Style="{StaticResource TrainerVersionActionButtonStyle}"
                           Appearance="Secondary"
                           Click="Cancel_Click"
                           Content="{DynamicResource TrainerVersionCancel}" />
            </DockPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>

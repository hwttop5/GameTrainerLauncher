<ui:FluentWindow x:Class="GameTrainerLauncher.UI.Views.UpdateProgressWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{DynamicResource UpdateDownloadTitle}"
                 Height="260"
                 Width="460"
                 MinHeight="260"
                 MinWidth="460"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 Icon="/Assets/logo.ico"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Foreground="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="UpdateProgressCardBrush" Color="#252729" />
        <SolidColorBrush x:Key="UpdateProgressBorderBrush" Color="#3C4045" />
        <SolidColorBrush x:Key="UpdateProgressMutedBrush" Color="#B8BEC7" />
        <SolidColorBrush x:Key="UpdateProgressAccentBrush" Color="#4CC2FF" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{DynamicResource UpdateDownloadTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/logo.ico" Width="16" Height="16" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24">
            <Border Padding="20"
                    Background="{StaticResource UpdateProgressCardBrush}"
                    BorderBrush="{StaticResource UpdateProgressBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource UpdateDownloadTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource UpdateProgressAccentBrush}" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,10,0,0"
                                   Text="{DynamicResource UpdateDownloadingMessage}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <ProgressBar x:Name="DownloadProgressBar"
                                 Grid.Row="1"
                                 Height="16"
                                 Margin="0,18,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="True" />

                    <TextBlock Grid.Row="2"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource UpdateProgressMutedBrush}"
                               Text="{DynamicResource UpdateRestartingMessage}"
                               Opacity="0.85"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>

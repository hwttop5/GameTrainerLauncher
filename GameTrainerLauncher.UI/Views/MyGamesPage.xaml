<Page x:Class="GameTrainerLauncher.UI.Views.MyGamesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:GameTrainerLauncher.UI.Converters"
      Title="{DynamicResource NavMyGames}">
    <Page.Resources>
        <converters:LessThanConverter x:Key="LessThanConverter"/>
    </Page.Resources>
    <Grid Margin="10">
        <ListView ItemsSource="{Binding Games}" SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="Margin" Value="0,4"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4" Background="#333" ClipToBounds="True">
                            <Grid>
                                <ui:SymbolIcon Symbol="Games24" FontSize="24" Foreground="Gray"
                                               Visibility="{Binding Converter={StaticResource GameCoverPlaceholderVisibilityConverter}}"/>
                                <Image Source="{Binding Converter={StaticResource GameCoverUrlConverter}}" Stretch="UniformToFill">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Converter={StaticResource GameCoverUrlConverter}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Foreground="Gray" FontSize="11" Margin="0,1,0,0">
                                <TextBlock.Text>
                                    <Binding Path="MatchedTrainer.LastUpdated" StringFormat="{}{0:yyyy.MM.dd}" TargetNullValue="—"/>
                                </TextBlock.Text>
                            </TextBlock>
                            
                            <ProgressBar Value="{Binding MatchedTrainer.DownloadProgress}" Maximum="100" Height="4" Margin="0,2,0,0">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource IsCurrentDownloadingConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.CurrentDownloadingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </StackPanel>
                        
                        <Grid Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Orientation" Value="Horizontal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=768}" Value="True">
                                                <Setter Property="Orientation" Value="Vertical"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <ui:Button Command="{Binding DataContext.DownloadTrainerCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Margin="4" Appearance="Secondary"
                                           Content="{DynamicResource BtnDownload}">
                                    <ui:Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource CanDownloadConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.CurrentDownloadingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                        </MultiBinding>
                                    </ui:Button.IsEnabled>
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MatchedTrainer.IsDownloaded}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>

                                <ui:Button Command="{Binding DataContext.LaunchTrainerCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Margin="4" Appearance="Primary">
                                    <ui:Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource CanLaunchConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.CurrentLaunchingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                        </MultiBinding>
                                    </ui:Button.IsEnabled>
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Content" Value="{DynamicResource BtnLaunch}"/>
                                            <Setter Property="Background" Value="#107C10"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="ToolTip" Value="{DynamicResource BtnLaunch}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MatchedTrainer.IsDownloaded}" Value="True">
                                                    <Setter Property="Background" Value="#107C10"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource IsCurrentLaunchingConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.CurrentLaunchingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Content" Value="{DynamicResource StatusDownloading}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MatchedTrainer}" Value="{x:Null}">
                                                     <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MatchedTrainer.IsDownloaded}" Value="False">
                                                     <Setter Property="ToolTip" Value="{DynamicResource MsgDownloadFirst}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>

                                <ui:Button Command="{Binding DataContext.RemoveGameCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Margin="4" Appearance="Danger"
                                           Content="{DynamicResource BtnRemove}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

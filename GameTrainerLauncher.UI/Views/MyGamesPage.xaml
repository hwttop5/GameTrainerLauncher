<Page x:Class="GameTrainerLauncher.UI.Views.MyGamesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:GameTrainerLauncher.UI.Converters"
      Title="{DynamicResource NavMyGames}">
    <Page.Resources>
        <converters:LessThanConverter x:Key="LessThanConverter"/>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,8"
                Visibility="{Binding PageFeedback.IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:InfoBar IsClosable="True"
                        IsOpen="{Binding PageFeedback.IsOpen, Mode=TwoWay}"
                        Severity="{Binding PageFeedback.Severity}"
                        Title="{Binding PageFeedback.Title}"
                        Message="{Binding PageFeedback.Message}"/>
        </Border>

        <ListView x:Name="GamesList" Grid.Row="1" ItemsSource="{Binding Games}" SelectionMode="Single" AllowDrop="True"
                  Visibility="{Binding HasGames, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="Margin" Value="0,0"/>
                    <Setter Property="Padding" Value="6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Padding="12,6,12,6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Cursor="Arrow">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*" MinWidth="230"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4" Background="{DynamicResource CoverPlaceholderBrush}" ClipToBounds="True">
                            <Grid>
                                <ui:SymbolIcon Symbol="Games24" FontSize="24" Foreground="{DynamicResource SecondaryTextBrush}">
                                    <ui:SymbolIcon.Visibility>
                                        <MultiBinding Converter="{StaticResource GameCoverPlaceholderFromPartsConverter}">
                                            <Binding Path="MatchedTrainer.ImageUrl"/>
                                            <Binding Path="CoverUrl"/>
                                            <Binding Path="Id"/>
                                        </MultiBinding>
                                    </ui:SymbolIcon.Visibility>
                                </ui:SymbolIcon>
                                <Image Stretch="UniformToFill">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource GameCoverFromPartsConverter}">
                                            <Binding Path="MatchedTrainer.ImageUrl"/>
                                            <Binding Path="CoverUrl"/>
                                            <Binding Path="Id"/>
                                        </MultiBinding>
                                    </Image.Source>
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="{x:Null}">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource GameCoverFromPartsConverter}">
                                                            <Binding Path="MatchedTrainer.ImageUrl"/>
                                                            <Binding Path="CoverUrl"/>
                                                            <Binding Path="Id"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Visibility="{Binding MatchedTrainer.Version, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <Run Text="{DynamicResource LabelTrainerVersion}" />
                                <Run Text=" " />
                                <Run Text="{Binding MatchedTrainer.Version}" />
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,6,0,4">
                                <TextBlock.Text>
                                    <Binding Path="MatchedTrainer.LastUpdated" StringFormat="{}{0:yyyy.MM.dd}" TargetNullValue="—"/>
                                </TextBlock.Text>
                            </TextBlock>
                            
                            <ProgressBar Value="{Binding MatchedTrainer.DownloadProgress}" Maximum="100" Height="4" Margin="0,2,0,0">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource IsCurrentDownloadingConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.CurrentDownloadingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                            <TextBlock Text="{Binding MatchedTrainer.DownloadStatusText}" FontSize="11" Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource IsCurrentDownloadingConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.CurrentDownloadingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        
                        <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Orientation" Value="Horizontal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=768}" Value="True">
                                                <Setter Property="Orientation" Value="Vertical"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <ui:Button Command="{Binding DataContext.LaunchTrainerCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Margin="4" Appearance="Primary">
                                    <ui:Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource CanLaunchConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.CurrentLaunchingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                        </MultiBinding>
                                    </ui:Button.IsEnabled>
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Content" Value="{DynamicResource BtnLaunch}"/>
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="ToolTip" Value="{DynamicResource BtnLaunch}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MatchedTrainer.IsDownloaded}" Value="True">
                                                    <Setter Property="Background" Value="#0078D4"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource IsCurrentLaunchingConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.CurrentLaunchingGame" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Content" Value="{DynamicResource StatusLaunching}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MatchedTrainer}" Value="{x:Null}">
                                                     <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MatchedTrainer.IsDownloaded}" Value="False">
                                                     <Setter Property="ToolTip" Value="{DynamicResource MsgDownloadFirst}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>

                                <ui:Button Command="{Binding DataContext.RemoveGameCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Margin="4" Appearance="Danger"
                                           Content="{DynamicResource BtnRemove}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- 仅当「我的游戏」加载完成且无数据时显示空状态 -->
        <Grid Grid.Row="1" Visibility="{Binding ShowNoGamesEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Games24" FontSize="64" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource MsgNoGamesTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center" Foreground="{DynamicResource EmptyStateTitleBrush}"/>
                <TextBlock Text="{DynamicResource MsgNoGamesDescription}" FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="600"/>
                <ui:Button Content="{DynamicResource BtnExplorePopular}" Appearance="Primary" Command="{Binding DataContext.NavigateToPopularCommand, RelativeSource={RelativeSource AncestorType=Page}}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

<ui:FluentWindow x:Class="GameTrainerLauncher.UI.Views.UpdatePromptWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{DynamicResource UpdateDialogTitle}"
                 Height="560"
                 Width="760"
                 MinHeight="560"
                 MinWidth="760"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 Icon="/Assets/logo.ico"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Foreground="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="UpdateDialogCardBrush" Color="#252729" />
        <SolidColorBrush x:Key="UpdateDialogHeaderBrush" Color="#2B2E31" />
        <SolidColorBrush x:Key="UpdateDialogBorderBrush" Color="#3C4045" />
        <SolidColorBrush x:Key="UpdateDialogMutedBrush" Color="#B8BEC7" />
        <SolidColorBrush x:Key="UpdateDialogAccentBrush" Color="#4CC2FF" />

        <Style x:Key="UpdateActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{DynamicResource UpdateDialogTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/logo.ico" Width="16" Height="16" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="18"
                    Background="{StaticResource UpdateDialogHeaderBrush}"
                    BorderBrush="{StaticResource UpdateDialogBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource UpdateDialogTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource UpdateDialogAccentBrush}" />
                        <TextBlock x:Name="SummaryText"
                                   Margin="0,10,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="12,6"
                            Margin="16,0,0,0"
                            VerticalAlignment="Top"
                            Background="#173E52"
                            BorderBrush="#2D6C87"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock Text="{DynamicResource UpdateReleaseNotes}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource UpdateDialogAccentBrush}" />
                    </Border>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="4,18,0,10"
                       Text="{DynamicResource UpdateReleaseNotes}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource UpdateDialogMutedBrush}" />

            <Border Grid.Row="2"
                    Background="{StaticResource UpdateDialogCardBrush}"
                    BorderBrush="{StaticResource UpdateDialogBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <TextBox x:Name="ReleaseNotesTextBox"
                         Margin="1"
                         Padding="18"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="{StaticResource UpdateDialogCardBrush}"
                         CaretBrush="{StaticResource UpdateDialogAccentBrush}"
                         SelectionBrush="#4056A3FF"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextWrapping="Wrap"
                         FontSize="14" />
            </Border>

            <DockPanel Grid.Row="3" Margin="0,18,0,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource UpdateDialogMutedBrush}"
                           Text="Velopack · GitHub Releases"
                           Opacity="0.85" />

                <ui:Button DockPanel.Dock="Right"
                           Style="{StaticResource UpdateActionButtonStyle}"
                           Appearance="Primary"
                           Click="UpdateNow_Click"
                           Content="{DynamicResource UpdateNow}" />
                <ui:Button DockPanel.Dock="Right"
                           Style="{StaticResource UpdateActionButtonStyle}"
                           Appearance="Secondary"
                           Click="RemindLater_Click"
                           Content="{DynamicResource UpdateLater}" />
                <ui:Button DockPanel.Dock="Right"
                           Style="{StaticResource UpdateActionButtonStyle}"
                           Appearance="Secondary"
                           Click="SkipVersion_Click"
                           Content="{DynamicResource UpdateSkipVersion}" />
            </DockPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>

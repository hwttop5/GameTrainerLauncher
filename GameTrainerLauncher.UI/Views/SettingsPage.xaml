<Page x:Class="GameTrainerLauncher.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource NavSettings}"
      Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="24" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource ApplicationBackgroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="16" MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelLanguage}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="LangEn" Content="English" GroupName="Lang" Tag="en-US" Checked="Language_Checked" Margin="0,0,24,0"/>
                            <RadioButton x:Name="LangZh" Content="中文" GroupName="Lang" Tag="zh-CN" Checked="Language_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
                <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="16" MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelTheme}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ThemeLight" Content="{DynamicResource ThemeLight}" GroupName="Theme" Tag="Light" Checked="Theme_Checked" Margin="0,0,24,0"/>
                            <RadioButton x:Name="ThemeDark" Content="{DynamicResource ThemeDark}" GroupName="Theme" Tag="Dark" Checked="Theme_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
                <ui:Card Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource UpdateSectionTitle}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{DynamicResource UpdateCurrentVersionLabel}" Margin="0,0,12,8" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CurrentVersionText" Grid.Column="1" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="{DynamicResource UpdateStatusLabel}" Margin="0,0,12,8" FontWeight="SemiBold"/>
                            <TextBlock x:Name="UpdateStatusText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2" Text="{DynamicResource UpdateLastCheckedLabel}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="UpdateLastCheckedText" Grid.Row="2" Grid.Column="1"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="CheckForUpdatesButton"
                                       Content="{DynamicResource UpdateCheckNow}"
                                       Click="CheckForUpdates_Click"
                                       Appearance="Primary"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource RepoSectionTitle}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource RepoDescription}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="OpenRepoButton"
                                       Content="{DynamicResource RepoOpenButton}"
                                       Click="OpenRepo_Click"
                                       Appearance="Secondary"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

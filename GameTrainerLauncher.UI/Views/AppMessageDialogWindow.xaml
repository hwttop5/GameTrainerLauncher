<ui:FluentWindow x:Class="GameTrainerLauncher.UI.Views.AppMessageDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Height="320"
                 Width="560"
                 MinHeight="320"
                 MinWidth="560"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 Icon="/Assets/logo.ico"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Foreground="{DynamicResource DialogTextBrush}">
    <Window.Resources>
        <Style x:Key="DialogActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="DialogTitleBar">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/logo.ico" Width="16" Height="16" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource NotificationSurfaceBrush}"
                    BorderBrush="{DynamicResource NotificationSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="4"
                                      Opacity="1"
                                      Color="{DynamicResource NotificationShadowColor}" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SeverityIconHost"
                            Width="36"
                            Height="36"
                            CornerRadius="18"
                            VerticalAlignment="Top"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="SeverityIconText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="DialogTitleText"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NotificationTitleBrush}"
                                   TextWrapping="Wrap" />
                        <ScrollViewer Margin="0,14,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="160">
                            <TextBlock x:Name="DialogMessageText"
                                       Foreground="{DynamicResource NotificationMessageBrush}"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Border>

            <DockPanel Grid.Row="1" Margin="0,18,0,0" LastChildFill="False">
                <ui:Button x:Name="PrimaryButton"
                           DockPanel.Dock="Right"
                           Style="{StaticResource DialogActionButtonStyle}"
                           Click="PrimaryButton_Click" />
                <ui:Button x:Name="SecondaryButton"
                           DockPanel.Dock="Right"
                           Style="{StaticResource DialogActionButtonStyle}"
                           Appearance="Secondary"
                           Click="SecondaryButton_Click" />
            </DockPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>

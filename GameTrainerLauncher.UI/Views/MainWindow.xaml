<ui:FluentWindow x:Class="GameTrainerLauncher.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource AppTitle}" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/logo.png"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar: icon 16x16 to fit without clipping -->
        <ui:TitleBar Title="{DynamicResource AppTitle}" Grid.Row="0">
             <ui:TitleBar.Icon>
                 <ui:ImageIcon Source="/Assets/logo.png" Width="16" Height="16"/>
             </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Side navigation (current page highlighted) -->
            <StackPanel Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <ui:Button Margin="10,8" HorizontalAlignment="Stretch"
                        Content="{DynamicResource NavPopular}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="Popular"
                        Appearance="{Binding IsPopularSelected, Converter={StaticResource BoolToAppearanceConverter}}"/>
                <ui:Button Margin="10,8" HorizontalAlignment="Stretch"
                        Content="{DynamicResource NavMyGames}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="MyGames"
                        Appearance="{Binding IsMyGamesSelected, Converter={StaticResource BoolToAppearanceConverter}}"/>
                <ui:Button Margin="10,8" HorizontalAlignment="Stretch"
                        Content="{DynamicResource NavSettings}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="Settings"
                        Appearance="{Binding IsSettingsSelected, Converter={StaticResource BoolToAppearanceConverter}}"/>
            </StackPanel>

            <!-- Content Area: search bar centered in this column, then frame -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8" HorizontalAlignment="Center" IsHitTestVisible="True" Panel.ZIndex="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Focusable="True"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{DynamicResource SearchPlaceholder}"
                                Width="320" VerticalAlignment="Center" Margin="0,0,8,0">
                        <ui:TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </ui:TextBox.InputBindings>
                    </ui:TextBox>
                    <ui:Button Grid.Column="1" Content="{DynamicResource BtnSearch}"
                               Command="{Binding SearchCommand}"
                               Appearance="Primary" VerticalAlignment="Center"/>
                </Grid>
                <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Background="{DynamicResource ApplicationBackgroundBrush}"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

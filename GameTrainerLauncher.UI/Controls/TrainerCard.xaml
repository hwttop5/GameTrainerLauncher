<UserControl x:Class="GameTrainerLauncher.UI.Controls.TrainerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:GameTrainerLauncher.UI.Converters"
             Width="220" MinHeight="280">
    <ui:Card Margin="10" Padding="0" VerticalAlignment="Top" Cursor="Hand"
             RenderTransformOrigin="0.5,0.5">
        <ui:Card.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </ui:Card.RenderTransform>
        <ui:Card.Style>
            <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ui:Card.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="140"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cover：亮色主题下使用浅灰占位，暗色使用深灰 -->
            <Border Grid.Row="0" Background="{DynamicResource CoverPlaceholderBrush}" CornerRadius="4,4,0,0" ClipToBounds="True">
                <Grid>
                    <ui:SymbolIcon Symbol="Games24" FontSize="48" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding ImageUrl, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Border>

            <!-- Title + Date: 日期上收下放，视觉上平衡（上面显宽时加大日期下边距） -->
            <StackPanel Grid.Row="1" Margin="10,2,10,0" VerticalAlignment="Top">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" Height="40" LineHeight="18" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" LineHeight="18" Margin="0,6,0,11">
                    <TextBlock.Text>
                        <Binding Path="LastUpdated" StringFormat="{}{0:yyyy.MM.dd}" TargetNullValue="—"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- Add button：添加中显示 loading + 进度条，下载完成后弹添加成功 -->
            <StackPanel Grid.Row="2" Margin="10,0,10,10">
                <Border BorderThickness="1"
                        BorderBrush="{Binding ElementName=AddButton, Path=Foreground, Converter={StaticResource BrushOpacityConverter}, ConverterParameter=0.25}"
                        CornerRadius="4">
                    <ui:Button x:Name="AddButton"
                               Command="{Binding DataContext.AddToMyGamesCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                               CommandParameter="{Binding}"
                               HorizontalAlignment="Stretch" VerticalAlignment="Top"
                               Foreground="{Binding RelativeSource={RelativeSource Self}, Path=IsEnabled, Converter={StaticResource EnabledToPrimaryForegroundBrushConverter}}"
                               BorderThickness="0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource BluePrimaryButtonStyle}">
                                <Setter Property="Content" Value="{DynamicResource BtnAdd}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content" Value="{DynamicResource StatusAdded}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAddPending}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content" Value="{DynamicResource StatusPreparingAdd}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAdding}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content" Value="{DynamicResource StatusAdding}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </Border>
                <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="6" Margin="0,6,0,0"
                             Visibility="{Binding IsAdding, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding DownloadStatusText}"
                           Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding IsAdding, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </ui:Card>
</UserControl>
